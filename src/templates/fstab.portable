{{ROOT_SPEC}} / ext4 noatime,errors=remount-ro 0 1
UUID={{BOOT_UUID}} /boot ext4 noatime,errors=remount-ro 0 2
UUID={{EFI_UUID}} /boot/efi vfat umask=0077 0 1
tmpfs /tmp tmpfs defaults,noatime,mode=1777 0 0
tmpfs /var/tmp tmpfs defaults,noatime,mode=1777,nosuid,nodev 0 0
tmpfs /var/log tmpfs defaults,noatime,mode=0755,nosuid,nodev 0 0
