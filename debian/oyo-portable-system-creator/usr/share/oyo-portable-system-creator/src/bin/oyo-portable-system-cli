#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

resolve_app_root() {
  if [[ -d "${script_dir}/../share/oyo-portable-system-creator/src" ]]; then
    cd -- "${script_dir}/../share/oyo-portable-system-creator" && pwd
    return
  fi
  if [[ -d "${script_dir}/../src" ]]; then
    cd -- "${script_dir}/../.." && pwd
    return
  fi
  echo "/usr/share/oyo-portable-system-creator"
}

app_root="$(resolve_app_root)"
cd "${app_root}"
export PYTHONPATH="${app_root}${PYTHONPATH:+:${PYTHONPATH}}"
exec python3 -m src.main "$@"
